# Copia este archivo a .env y rellena tus credenciales reales de Applivery.
# El producto funciona SIN esto en modo simulacion (mode=simulation en config.json).

# API key de Applivery (Service Account con acceso a Organizations API).
# Con esto, el motor pasa a modo 'live' y consulta ubicaciones reales cada 15 min.
APPLIVERY_API_KEY=

# Base opcional si tu tenant usa otro host (por defecto https://api.applivery.io/v1)
# APPLIVERY_API_BASE=https://api.applivery.io/v1

# Microsoft Intune (live mode via Microsoft Graph) — issue #1
# 1) Registra una app en Azure AD (Entra ID):
#    - Permiso de aplicacion: DeviceManagementConfiguration.ReadWrite.All (no delegated)
#    - Crea un client secret; rellena abajo
# 2) El adapter se mantiene en MOCK mode si INTUNE_TENANT_ID esta vacio.
INTUNE_TENANT_ID=
INTUNE_CLIENT_ID=
INTUNE_CLIENT_SECRET=
# INTUNE_ENDPOINT=https://graph.microsoft.com/v1.0

# VMware Workspace ONE UEM (opcional; sin valores permanece en modo mock)
WORKSPACE_ONE_BASE_URL=
WORKSPACE_ONE_TENANT_CODE=
WORKSPACE_ONE_USERNAME=
WORKSPACE_ONE_PASSWORD=

