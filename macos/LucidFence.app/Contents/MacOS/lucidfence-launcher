#!/bin/bash
# Native macOS launcher. Lifecycle ownership stays in the LucidFence CLI;
# this wrapper never kills unrelated Python processes or scans ports.
set -eu

LUCIDFENCE_BIN="$(command -v lucidfence || true)"
if [ -z "$LUCIDFENCE_BIN" ]; then
  for candidate in /opt/homebrew/bin/lucidfence /usr/local/bin/lucidfence; do
    if [ -x "$candidate" ]; then
      LUCIDFENCE_BIN="$candidate"
      break
    fi
  done
fi

if [ -z "$LUCIDFENCE_BIN" ]; then
  osascript -e 'display dialog "LucidFence no está instalado.\n\nEjecuta:\nbrew tap adrimg3196/lucidfence\nbrew install lucidfence" buttons {"OK"} default button 1 with icon caution' 2>/dev/null || true
  exit 1
fi

exec "$LUCIDFENCE_BIN" start
